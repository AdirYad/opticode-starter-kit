# Copy to .env and fill in. Next.js loads .env automatically (not .env.local).
# Never commit .env. NEXT_PUBLIC_ vars ship to the browser; the rest stay server-only.

# App base URL. Local defaults to this; set your domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase: Dashboard, your project, Settings, API keys. (anon key is browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase: "Connect" button, Connection string. Swap in your DB password.
# Use a pooler URI on IPv4-only networks. prepare:false in src/db/index.ts handles it.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Get it at https://vercel.com/ai-gateway . Auto-injected on Vercel deploys.
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
# Default model as "<provider>/<model>". Optional, defaults to openai/gpt-4o-mini.
AI_DEFAULT_MODEL=openai/gpt-4o-mini
