# Opticode Starter environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# Next.js loads .env automatically. This project does not use .env.local.

# App
# Public base URL of the app. Used for metadata, sitemap, and robots.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Supabase Dashboard, Project Settings, API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Database (Drizzle)
# Supabase Dashboard, Project Settings, Database, Connection string.
# Used by the app at runtime and by drizzle-kit migrations. Either the direct
# connection or the pooler string works (prepare:false is set in src/db/index.ts).
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Vercel AI Gateway
# vercel.com, AI Gateway, API Keys. One key routes to every model provider.
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
# Default model as "<provider>/<model>", e.g. openai/gpt-4o-mini or anthropic/claude-sonnet-4.5
AI_DEFAULT_MODEL=openai/gpt-4o-mini
