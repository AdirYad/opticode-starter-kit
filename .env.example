# ─────────────────────────────────────────────────────────────────────────
# Opticode Starter — environment variables
# Copy this file to .env and fill in real values.  NEVER commit .env.
# Next.js loads .env automatically. We do not use .env.local in this project.
# ─────────────────────────────────────────────────────────────────────────

# App ----------------------------------------------------------------------
# Public base URL of the app. Used for metadata, sitemap, and robots.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase -----------------------------------------------------------------
# Supabase Dashboard → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Database (Drizzle) -------------------------------------------------------
# Supabase Dashboard → Project Settings → Database → Connection string.
# DATABASE_URL  = "Transaction" pooler (port 6543). Used by the app at runtime.
#                 Prepared statements are disabled for this mode (see src/db/index.ts).
# DIRECT_URL    = "Session" / direct connection (port 5432). Used ONLY by
#                 drizzle-kit for migrations (db:generate / db:migrate / db:push).
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Vercel AI Gateway --------------------------------------------------------
# vercel.com → AI Gateway → API Keys. One key routes to every model provider.
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
# Default model as "<provider>/<model>", e.g. openai/gpt-4o-mini, anthropic/claude-sonnet-4.5
AI_DEFAULT_MODEL=openai/gpt-4o-mini
